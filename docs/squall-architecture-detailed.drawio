        </mxCell>
        <mxCell id="db_plp" value="&lt;b&gt;Balance&amp;lt;PLP&amp;gt;&lt;/b&gt;&lt;br&gt;&lt;br&gt;The house's live position.&lt;br&gt;Marked to NAV each epoch.&lt;br&gt;&lt;font color=&quot;#b00020&quot;&gt;A tail hedge caps the crash.&lt;/font&gt;" style="rounded=8;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#1a73c0;fontSize=12;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="530" y="540" width="210" height="160" as="geometry" />
