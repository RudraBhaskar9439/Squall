        <mxCell id="db_book" value="&lt;b&gt;Vol-priced order book&lt;/b&gt;&lt;br&gt;&lt;br&gt;Traders pay the &lt;b&gt;spread&lt;/b&gt; —&lt;br&gt;real, recurring flow&lt;br&gt;(not a cheap auction)." style="rounded=8;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#1a73c0;fontSize=12;align=left;spacingLeft=8;" vertex="1" parent="1">
