        <mxCell id="wal_web" value="&lt;b&gt;Proof tab (web)&lt;/b&gt;&lt;br&gt;&lt;br&gt;Anyone re-checks a past&lt;br&gt;epoch live.&lt;br&gt;&lt;b&gt;Trust by proof,&lt;br&gt;not by promise.&lt;/b&gt;" style="rounded=8;whiteSpace=wrap;html=1;fillColor=#eafaf4;strokeColor=#18a07a;fontSize=12;align=left;spacingLeft=8;" vertex="1" parent="1">
