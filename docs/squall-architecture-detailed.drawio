        </mxCell>
        <mxCell id="wal_store" value="&lt;b&gt;stored on nodes&lt;/b&gt;&lt;br&gt;&lt;br&gt;immutable · erasure-coded&lt;br&gt;→ returns &lt;b&gt;blobId&lt;/b&gt;&lt;br&gt;(content hash)" style="rounded=8;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#18a07a;fontSize=12;align=left;spacingLeft=8;" vertex="1" parent="1">
