<mxfile host="app.diagrams.net" type="device">
  <diagram id="squall-simple" name="Squall — Story Architecture">
    <mxGraphModel dx="1000" dy="700" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1000" pageHeight="880" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- ===================== OCEAN BANDS (background) ===================== -->
        <mxCell id="band_surface" value="" style="rounded=0;html=1;fillColor=#eaf6ff;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="0" y="40" width="1000" height="190" as="geometry" />
        </mxCell>
        <mxCell id="band_mid" value="" style="rounded=0;html=1;fillColor=#d6ecf8;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="0" y="230" width="1000" height="220" as="geometry" />
        </mxCell>
        <mxCell id="band_depths" value="" style="rounded=0;html=1;fillColor=#bcdcef;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="0" y="450" width="1000" height="200" as="geometry" />
        </mxCell>
        <mxCell id="band_seabed" value="" style="rounded=0;html=1;fillColor=#a6cce0;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="0" y="650" width="1000" height="200" as="geometry" />
        </mxCell>

        <!-- band labels -->
        <mxCell id="lbl_surface" value="🌅  SURFACE" style="text;html=1;align=left;verticalAlign=middle;fontSize=13;fontStyle=2;fontColor=#5a7a90;" vertex="1" parent="1">
          <mxGeometry x="24" y="48" width="160" height="24" as="geometry" />
        </mxCell>
        <mxCell id="lbl_depths" value="🌊  DEEPBOOK'S DEPTHS" style="text;html=1;align=left;verticalAlign=middle;fontSize=13;fontStyle=2;fontColor=#3a5e74;" vertex="1" parent="1">
          <mxGeometry x="24" y="458" width="220" height="24" as="geometry" />
        </mxCell>
        <mxCell id="lbl_seabed" value="🐚  WALRUS SEABED" style="text;html=1;align=left;verticalAlign=middle;fontSize=13;fontStyle=2;fontColor=#2c4d61;" vertex="1" parent="1">
          <mxGeometry x="24" y="658" width="200" height="24" as="geometry" />
        </mxCell>

        <!-- title -->
        <mxCell id="title" value="Squall — one continuous dive into the Sui ocean" style="text;html=1;align=center;verticalAlign=middle;fontSize=20;fontStyle=1;fontColor=#103a52;" vertex="1" parent="1">
          <mxGeometry x="220" y="4" width="560" height="34" as="geometry" />
        </mxCell>

        <!-- ===================== NODES ===================== -->
        <!-- User -->
        <mxCell id="user" value="&lt;b&gt;You (LP)&lt;/b&gt;&lt;br&gt;Deposit USDC → receive vault shares.&lt;br&gt;Withdraw anytime." style="rounded=12;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#5a7a90;strokeWidth=2;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="380" y="80" width="240" height="100" as="geometry" />
        </mxCell>

        <!-- Vol Index -->
        <mxCell id="volindex" value="&lt;b&gt;On-chain Vol Index&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#1a73c0&quot;&gt;the 1st on Sui&lt;/font&gt;&lt;br&gt;the fair price of risk" style="rounded=12;whiteSpace=wrap;html=1;fillColor=#fff6da;strokeColor=#d6a400;strokeWidth=2;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="60" y="270" width="230" height="110" as="geometry" />
        </mxCell>

        <!-- Vault (hub) -->
        <mxCell id="vault" value="&lt;b&gt;SQUALL VAULT&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:12px&quot;&gt;ERC-4626 structured vault on Sui&lt;br&gt;routes deposits · marks NAV · hedged&lt;/font&gt;" style="rounded=12;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#103a52;strokeWidth=3;fontSize=15;" vertex="1" parent="1">
          <mxGeometry x="370" y="260" width="260" height="130" as="geometry" />
        </mxCell>

        <!-- Keeper -->
        <mxCell id="keeper" value="&lt;b&gt;Keeper&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:12px&quot;&gt;off-chain automation&lt;br&gt;updates index · writes proof&lt;/font&gt;" style="rounded=12;whiteSpace=wrap;html=1;fillColor=#eef7ec;strokeColor=#5a9c4c;strokeWidth=2;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="710" y="270" width="230" height="110" as="geometry" />
        </mxCell>

        <!-- DeepBook Predict (SPONSOR) -->
        <mxCell id="predict" value="&lt;b&gt;DeepBook Predict&lt;/b&gt;  ★ SPONSOR&lt;br&gt;&lt;br&gt;The vol-surface-priced order book.&lt;br&gt;Squall is &lt;b&gt;the house&lt;/b&gt; — LPs the book and&lt;br&gt;&lt;b&gt;earns the spread from real trading flow&lt;/b&gt;.&lt;br&gt;&lt;font color=&quot;#b00020&quot;&gt;A tail hedge caps the crash that killed the old vaults.&lt;/font&gt;" style="rounded=14;whiteSpace=wrap;html=1;fillColor=#d4e9ff;strokeColor=#1a73c0;strokeWidth=4;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="290" y="480" width="420" height="150" as="geometry" />
        </mxCell>

        <!-- Walrus (SPONSOR) -->
        <mxCell id="walrus" value="&lt;b&gt;Walrus&lt;/b&gt;  ★ SPONSOR&lt;br&gt;&lt;br&gt;Every epoch's NAV is written as an &lt;b&gt;immutable, content-addressed blob&lt;/b&gt;.&lt;br&gt;= a &lt;b&gt;verifiable track record&lt;/b&gt; anyone can re-fetch and check. Trust by proof, not promise." style="rounded=14;whiteSpace=wrap;html=1;fillColor=#d4f3ea;strokeColor=#18a07a;strokeWidth=4;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="290" y="690" width="420" height="135" as="geometry" />
        </mxCell>

        <!-- ===================== STORY ARROWS (numbered) ===================== -->
        <mxCell id="e1" value="①  Deposit USDC → shares" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;fontSize=13;fontStyle=1;strokeWidth=2;strokeColor=#5a7a90;" edge="1" parent="1" source="user" target="vault">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e2" value="②  reads DeepBook's vol surface" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;dashed=1;fontSize=12;fontStyle=1;strokeWidth=2;strokeColor=#1a73c0;" edge="1" parent="1" source="predict" target="keeper">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e3" value="③  publishes the Vol Index" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;fontSize=12;fontStyle=1;strokeWidth=2;strokeColor=#d6a400;" edge="1" parent="1" source="keeper" target="volindex">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e3b" value="prices risk" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;dashed=1;fontSize=11;strokeWidth=2;strokeColor=#d6a400;" edge="1" parent="1" source="volindex" target="vault">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e4" value="④  be the house — earn the spread" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;startArrow=classic;fontSize=13;fontStyle=1;strokeWidth=3;strokeColor=#1a73c0;" edge="1" parent="1" source="vault" target="predict">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e5" value="⑤  snapshot NAV each epoch" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;fontSize=12;fontStyle=1;strokeWidth=2;strokeColor=#18a07a;" edge="1" parent="1" source="keeper" target="walrus">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e6" value="⑥  verify the track record" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;dashed=1;fontSize=12;fontStyle=1;strokeWidth=2;strokeColor=#18a07a;exitX=0.1;exitY=0;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="walrus" target="user">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
